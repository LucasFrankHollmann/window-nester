<UserControl
    x:Class="WindowGroupManager.Views.Controls.WindowDock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WindowGroupManager.Services"
    xmlns:controls="clr-namespace:WindowGroupManager.Views.Controls">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
        <controls:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibility"/>
    </UserControl.Resources>

    <Grid
        x:Name="HostBorder"
        Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top controls: Attach (when empty) OR Detach (when attached) -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            HorizontalAlignment="Stretch">

            <StackPanel
                Orientation="Vertical"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Visibility="{Binding IsEmpty, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibility}}">
                <Button
                    x:Name="AttachButton"
                    Content="Attach Window"
                    Click="AttachWindowButton_Click"
                    Width="100"
                    Margin="8"/>
            </StackPanel>

            <Button
                x:Name="DetachButton"
                Grid.Row="0"
                Content="Detach"
                Click="DetachWindowButton_Click"
                HorizontalAlignment="Right"
                Margin="8"
                Padding="6,2"
                Visibility="{Binding IsEmpty, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InvertedBooleanToVisibility}}"/>
        </StackPanel>

        <!-- Host occupies second row so native child doesn't cover top controls -->
        <local:WindowHost
            x:Name="Host"
            Grid.Row="1"
            Visibility="{Binding IsEmpty, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InvertedBooleanToVisibility}}"/>
        
    </Grid>

</UserControl>