<Window
    x:Class="WindowGroupManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:WindowGroupManager.Views.Controls"
    Title="Window Group Manager"
    Height="600"
    Width="900">


    <Grid Margin="10">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="420"/>

        </Grid.RowDefinitions>


        <!-- Botões -->
        <StackPanel Orientation="Horizontal">

            <Button
                Content="Atualizar"
                Click="RefreshButton_Click"
                Width="100"/>


            <Button
                Content="Anexar Esquerda"
                Click="AttachLeftButton_Click"
                Margin="10,0,0,0"/>


            <Button
                Content="Anexar Direita"
                Click="AttachRightButton_Click"
                Margin="10,0,0,0"/>

        </StackPanel>



        <!-- Informações -->
        <TextBlock
            x:Name="SelectedWindowInfo"
            Grid.Row="1"
            Margin="0,10"/>



        <!-- Lista -->
        <ListBox
            x:Name="WindowsList"
            Grid.Row="2"
            Margin="0,10,0,10"/>



        <!-- Docks -->
        <Grid
            Grid.Row="3">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>


            <Border
                Grid.Column="0"
                BorderThickness="1"
                BorderBrush="Gray">

                <views:WindowDock
                    x:Name="LeftDock"/>

            </Border>



            <Border
                Grid.Column="1"
                BorderThickness="1"
                BorderBrush="Gray">

                <views:WindowDock
                    x:Name="RightDock"/>

            </Border>


        </Grid>


    </Grid>

</Window>