<Window
    x:Class="WindowGroupManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:WindowGroupManager.Views.Controls"
    Title="Window Group Manager"
    Height="600"
    Width="900">


    <Grid Margin="10">

        <Grid.RowDefinitions>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- Docks -->
        <Grid
            Grid.Row="0">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>


            <Border
                Grid.Column="0"
                BorderThickness="1"
                BorderBrush="Gray">

                <views:WindowDock
                    x:Name="LeftDock"/>

            </Border>



            <Border
                Grid.Column="1"
                BorderThickness="1"
                BorderBrush="Gray">

                <views:WindowDock
                    x:Name="RightDock"/>

            </Border>


        </Grid>

    </Grid>

</Window>